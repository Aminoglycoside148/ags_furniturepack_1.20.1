{
  "multipart": [
    {
      "when": {"left": true, "facing": "north"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_left", "y": 0}
    },
    {
      "when": {"left": true, "facing": "east"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_left", "y": 90}
    },
    {
      "when": {"left": true, "facing": "south"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_left", "y": 180}
    },
    {
      "when": {"left": true, "facing": "west"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_left", "y": 270}
    },

    {
      "when": {"right": true, "facing": "north"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_right", "y": 0}
    },
    {
      "when": {"right": true, "facing": "east"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_right", "y": 90}
    },
    {
      "when": {"right": true, "facing": "south"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_right", "y": 180}
    },
    {
      "when": {"right": true, "facing": "west"},
      "apply": {"model": "ags_furniturepack:block/railing/glass_stair_rail_right", "y": 270}
    }
  ]
}